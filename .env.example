# Copy to .env (or just export). Unset → the demo runs offline with a
# deterministic stub model + a toy hash embedder.

# Provider-agnostic chat model id for langchain.init_chat_model:
#   CHAT_MODEL=anthropic:claude-sonnet-4-6
#   CHAT_MODEL=openai:gpt-4o
# (install the matching extra: pip install -e ".[anthropic]"  or  ".[openai]")
# CHAT_MODEL=

# Embeddings model for the Store's semantic index:
#   EMBEDDINGS_MODEL=openai:text-embedding-3-small
# EMBEDDINGS_MODEL=

# Provider keys, as required by your chosen models:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
